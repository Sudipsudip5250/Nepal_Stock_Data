# GitHub Bot Configuration for NEPSE Data Automation
# Copy this file to .env and fill in your values for local testing

# Bot email address (for git commits in local/Colab environments)
# GitHub Actions will use the value from repository secrets
USER_EMAIL_GITHUB=bot@nepal-stock-data.local

# Bot username (appears in commit author line)
# GitHub Actions will use the value from repository secrets
USERNAME_GITHUB=NepalStockData[bot]

# GitHub Personal Access Token (for local testing ONLY)
# Leave empty when using GitHub Actions
# Create token with 'repo' scope only at: github.com/settings/tokens
# NEVER commit .env file with actual token!
TOKEN_GITHUB=
